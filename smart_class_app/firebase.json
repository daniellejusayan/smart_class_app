{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "predeploy": [
      "bash scripts/sync_web_to_hosting.sh"
    ],
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/app/**",
        "destination": "/app/index.html"
      }
    ]
  }
}
